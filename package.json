{
  "name": "m-finlogs",
  "productName": "M-Finlogs",
  "version": "0.1.3-gamma.1",
  "description": "Accounting Software for M-Finlogs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "preflight:build": "node scripts/preflight-build.js",
    "build:backend": "py -3.12 -m PyInstaller --noconfirm --clean --onefile --name backend --distpath dist --workpath build backend_runner.py || python -m PyInstaller --noconfirm --clean --onefile --name backend --distpath dist --workpath build backend_runner.py",
    "dist": "set \"ComSpec=C:\\Windows\\System32\\cmd.exe\" && set \"PATH=%SystemRoot%\\System32;%PATH%\" && electron-builder",
    "dist:with-backend": "npm run preflight:build && npm run build:backend && npm run dist"
  },
  "build": {
    "appId": "com.mfinlogs.app",
    "productName": "M-Finlogs",
    "publish": [
      {
        "provider": "github",
        "owner": "ektharxd",
        "repo": "M-Finlogs"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/finlogs.ico"
    },
    "extraResources": [
      {
        "from": "dist/backend.exe",
        "to": "backend.exe"
      }
    ]
  },
  "keywords": [],
  "author": "Ekthar",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "exceljs": "^4.4.0",
    "electron-updater": "^6.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0"
  }
}